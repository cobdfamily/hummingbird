# Default credentials used by /login when no plugin is active.
HUMMINGBIRD_USERNAME=
HUMMINGBIRD_PASSWORD=

# Name of the plugin to load (must match a `hummingbird.plugins` entry point).
# Leave empty for standalone JSON-backed operation.
HUMMINGBIRD_PLUGIN=

# Optional: public HTTP source from which /download falls back when a file
# is not in the local cache. Expected layout: {URL}/{format}/{id}/{filename}.
HUMMINGBIRD_PUBLIC_CONTENT_URL=

# Storage locations (defaults are fine for dev).
HUMMINGBIRD_DATA_DIR=./data
HUMMINGBIRD_CACHE_DIR=./cache

# Server bind.
HUMMINGBIRD_HOST=0.0.0.0
HUMMINGBIRD_PORT=8000

# Kados app-level API key. Optional. When set, requests must supply
# X-API-Key matching this value.
KADOS_API_KEY=
